set autoindent
set ignorecase
set smartcase


nnoremap <C-b> ^
xnoremap <C-f> $
xnoremap <C-b> ^
onoremap <C-f> $
onoremap <C-b> ^
inoremap <C-f> <ESC>A
inoremap <C-b> <ESC>I
nnoremap <Cr> %
nnoremap <silent> c<Cr> *Ncgn

nnoremap <silent> gh :tabprevious<CR>
nnoremap <silent> gl :tabnext<CR>
nnoremap <silent> <leader>l :tabm +1<CR>
nnoremap <silent> <leader>h :tabm -1<CR>
nnoremap <silent> <leader>1 :tabm 0<CR>
nnoremap <silent> <leader>0 :tabm<CR>
