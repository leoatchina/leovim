set ignorecase
set ignorecase
set smartcase
set scrolloff=3 " 3 lines above/below cursor when scrolling
" Copy to system clipboard as well
set clipboard+=unnamed
" Use Idea to join lines smartly
set ideajoin

" 缩进
nmap <A-.> >>
xmap <A-.> >gv
xmap >>    >gv
nmap <A-,> <<
xmap <A-,> <gv
xmap <<    <gv
nmap q <Nop>
vmap q <Nop>
nmap Q q
vmap Q q

" home end
nmap L $
nmap H ^

"
nmap <Cr> %
vmap <Cr> %

" Closing tabs
nmap <space>q :action CloseContent<cr>
nmap <space>o :action ReopenClosedTab<cr>

" To navigate between split panes
nmap <A-]> :action NextSplitter<cr>
nmap <A-[> :action PrevSplitter<cr>

" Splits manipulation
nmap <space>X :action SplitHorizontally<cr>
nmap <space>V :action SplitVertically<cr>

" Tabs
nnoremap gh :action PreviousTab<cr>
nnoremap gl :action NextTab<cr>

" Navigation
nmap gd :action GotoDefinition<cr>
nmap gt :action GotoTypeDefinition<cr>
nmap gy :action GotoDeclaration<cr>
nmap gf :action GotoFile<cr>
nmap gc :action GotoClass<cr>
nmap gs :action GotoSymbol<cr>
nmap gi :action GotoImplementation<cr>
nmap gT :action GotoTest<cr>
nmap <space>h :action Back<cr>
nmap <space>l :action Forward<cr>
nmap <space>p :action FileStructurePopup<cr>
nmap <space>u :action FindUsages<cr>
nmap <space>a :action ActivateStructureToolWindow<cr>
nmap <space>d :action ShowErrorDescription<cr>
nmap <space>i :action SelectIn<cr>
nmap <space>f :action RecentFiles<cr>
nmap <space>b :action ShowBookmarks<cr>

" nmap <space>a :action Switcher<cr>

" Errors
nmap <space>n :action GotoNextError<cr>
nmap <space>p :action GotoPreviousError<cr>

" Refactorings
vmap M :action Refactorings.QuickListPopupAction<cr>
nmap <space>rr :action RenameElement<cr>
nmap <space>rg :action Generate<cr>
nmap <space>ri :action OptimizeImports<cr>
" Inspection
nmap <space>rc :action InspectCode<cr>

" VCS operations
nmap <space>yy :action Vcs.Show.Local.Changes<cr>
nmap <space>yp :action Vcs.QuickListPopupAction<cr>
nmap <space>ya :action Annotate<cr>
nmap <space>yl :action Vcs.Show.Log<cr>
nmap <space>yd :action Compare.LastVersion<cr>
nmap <space>yr :action Git.ResolveConflicts<cr>

" Terminal
nmap <A--> :action ActivateTerminalToolWindow<cr>

" Won't work in visual mode (with vmap) for some reason.
" Use default map of <c-/> for that.
nmap <space>cc :action CommentByLineComment<cr>

" unimpaired mappings - from https://github.com/saaguero/ideavimrc/blob/master/.ideavimrc
nnoremap [o :action PreviousOccurence<cr>
nnoremap ]o :action NextOccurence<cr>
nnoremap [m :action MethodUp<cr>
nnoremap ]m :action MethodDown<cr>
nnoremap [c :action VcsShowPrevChangeMarker<cr>
nnoremap ]c :action VcsShowNextChangeMarker<cr>


" Search
nmap <space>/ :action Find<cr>
nmap <space>\ :action FindInPath<cr>

" Moving lines
nmap [e :action MoveLineUp<cr>
nmap ]e :action MoveLineDown<cr>
" Moving statements
nmap [s :action MoveStatementUp<cr>
nmap ]s :action MoveStatementDown<cr>

" Building, Running and Debugging
nmap \c :action CompileDirty<cr>
nmap \r :action Run<cr>
nmap \R :action RunAnything<cr>
nmap \b :action Debug<cr>
nmap \C :action RunClass<cr>
nmap \d :action DebugClass<cr>
nmap \t :action RerunTests<cr>
nmap \T :action RerunFailedTests<cr>

" Clojure specific mappings for Cursive
nmap \\c :action :cursive.repl.actions/clear-repl<cr>
nmap \\l :action :cursive.repl.actions/load-file<cr>
nmap \\o :action :cursive.repl.actions/jump-to-output<cr>
nmap \\r :action :cursive.repl.actions/jump-to-repl<cr>
nmap \\t :action :cursive.testing.actions/run-ns-tests<cr>
nmap \\T :action :cursive.testing.actions/rerun-last-test<cr>
nmap \\C :action :cursive.testing.actions/remove-test-markers<cr>

" Python specific mappings
" Format code with Black fomatter
nmap \p :action Tool_External Tools_Black<cr>

